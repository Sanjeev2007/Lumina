# Cross-device sync (optional).
# Create a free Supabase project (https://supabase.com), run docs/supabase-schema.sql,
# then paste your Project URL and anon/public key below. These are safe to expose
# in the client. Leave both unset to run Lumina in local-only mode (no sync).
#
# Copy this file to .env.local and fill in your values.
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR-ANON-PUBLIC-KEY"
